{
  "name": "200mph/myxa",
  "description": "Myxa, a lightweight and flexible AI-powered PHP framework.",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Wojciech Brozyna",
      "email": "wojciech.brozyna@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Test\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.4",
    "200mph/myxa-framework": "dev-develop"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^1.12",
    "squizlabs/php_codesniffer": "^3.11"
  },
  "scripts": {
    "test": "vendor/bin/phpunit -c phpunit.xml",
    "test:unit": "vendor/bin/phpunit -c phpunit.xml tests/Unit",
    "test:coverage": "vendor/bin/phpunit -c phpunit.xml --coverage-text",
    "test:coverage:html": "vendor/bin/phpunit -c phpunit.xml --coverage-html build/coverage",
    "route:cache": "./myxa route:cache",
    "route:clear": "./myxa route:clear",
    "phpstan": "vendor/bin/phpstan analyse -c phpstan.neon.dist",
    "phpcs": "vendor/bin/phpcs --standard=phpcs.xml.dist"
  }
}
