<IfModule mod_dir.c>
    DirectoryIndex index.php
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Let Apache serve existing files and directories directly.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route all other requests through the PHP front controller.
    RewriteRule ^ index.php [L]
</IfModule>
